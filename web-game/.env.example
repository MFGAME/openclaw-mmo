# OpenClaw MMO - 环境变量配置模板
#
# 复制此文件为 .env 并根据需要修改配置值

# ============================================
# 应用配置
# ============================================

# 运行环境：development | production
NODE_ENV=production

# 日志级别：error | warn | info | debug
LOG_LEVEL=info

# ============================================
# 端口配置
# ============================================

# HTTP 端口（静态文件服务）
HTTP_PORT=80

# WebSocket 端口（游戏服务器）
WS_PORT=8081

# ============================================
# WebSocket 配置
# ============================================

# 心跳检测间隔（毫秒）
WS_HEARTBEAT_INTERVAL=30000

# 心跳超时时间（毫秒）
WS_HEARTBEAT_TIMEOUT=90000

# ============================================
# 游戏配置
# ============================================

# 最大在线玩家数
MAX_PLAYERS=1000

# 最大房间数
MAX_ROOMS=100

# 匹配超时时间（毫秒）
MATCHMAKING_TIMEOUT=60000

# ============================================
# 数据库配置（可选）
# ============================================

# PostgreSQL 数据库端口
DB_PORT=5432

# 数据库名称
DB_NAME=openclaw

# 数据库用户
DB_USER=openclaw

# 数据库密码（生产环境请使用强密码）
DB_PASSWORD=changeme

# ============================================
# Redis 配置（可选）
# ============================================

# Redis 端口
REDIS_PORT=6379

# Redis 密码（如需认证）
# REDIS_PASSWORD=your_redis_password

# ============================================
# 资源限制配置
# ============================================

# 主应用 CPU 限制
CPU_LIMIT=1

# 主应用内存限制
MEMORY_LIMIT=512M

# 主应用 CPU 保留
CPU_RESERVATION=0.25

# 主应用内存保留
MEMORY_RESERVATION=128M

# Redis CPU 限制
REDIS_CPU_LIMIT=0.5

# Redis 内存限制
REDIS_MEMORY_LIMIT=256M

# Redis CPU 保留
REDIS_CPU_RESERVATION=0.1

# Redis 内存保留
REDIS_MEMORY_RESERVATION=64M

# 数据库 CPU 限制
DB_CPU_LIMIT=1

# 数据库内存限制
DB_MEMORY_LIMIT=1G

# 数据库 CPU 保留
DB_CPU_RESERVATION=0.25

# 数据库内存保留
DB_MEMORY_RESERVATION=256M

# ============================================
# 安全配置
# ============================================

# 允许的 CORS 源（逗号分隔）
CORS_ORIGINS=http://localhost:8080,http://localhost:80

# 会话密钥（生产环境请使用随机字符串）
SESSION_SECRET=change_me_to_random_string_in_production

# JWT 密钥（生产环境请使用随机字符串）
JWT_SECRET=change_me_to_random_string_in_production

# ============================================
# 第三方服务配置（可选）
# ============================================

# 飞书应用 ID
# FEISHU_APP_ID=your_app_id

# 飞书应用密钥
# FEISHU_APP_SECRET=your_app_secret

# 飞书事件回调地址
# FEISHU_VERIFICATION_TOKEN=your_verification_token

# ============================================
# 监控和日志配置
# ============================================

# 是否启用详细日志
ENABLE_VERBOSE_LOGGING=false

# 日志文件路径
LOG_PATH=/var/log/openclaw

# 是否启用性能监控
ENABLE_PERFORMANCE_MONITORING=true

# ============================================
# 功能开关
# ============================================

# 是否启用机器人
ENABLE_BOTS=true

# 最大机器人数量
MAX_BOTS=10

# 机器人行为调试
BOT_DEBUG_MODE=false

# ============================================
# 其他配置
# ============================================

# 时区
TZ=Asia/Shanghai

# 语言
LANG=zh_CN.UTF-8
