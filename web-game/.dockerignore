dist/
*.tsbuildinfo

# 编辑器配置
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# 测试和覆盖率
coverage/
.nyc_output/
*.test.ts
*.spec.ts
__tests__/
jest.config.js

# 文档
README.md
CHANGELOG.md
LICENSE
docs/

