.github/
.gitlab-ci.yml
.travis.yml

# 环境配置
.env
.env.local
.env.*.local

# 日志
logs/
*.log

# 临时文件
tmp/
temp/
*.tmp

# 操作系统文件
Thumbs.db
desktop.ini

